{
  "crons": [
    {
      "path": "/api/cron/refresh-metrics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-blog-metadata",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/refresh-credly",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/CV-JEROHAM-SANCHEZ-SR-FULLSTACK-ENGINEER.pdf",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"CV-JEROHAM-SANCHEZ-SR-FULLSTACK-ENGINEER.pdf\""
        }
      ]
    }
  ]
}
